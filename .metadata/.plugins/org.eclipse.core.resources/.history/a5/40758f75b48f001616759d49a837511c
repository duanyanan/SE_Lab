class Simplify {
	//뇹잿뜩淃駕쏵契덜令，헹돔。
	private StringBuffer m;
	public	String out(final StringBuffer  str) {
	final int ten = 10;
	final int twelve = 12;
	final int four = 4;
	//渴흙뜩淃駕
	if ((str.indexOf("!simplify") == -1) && (str.indexOf("!d/d") == -1)) {
		//str.in(); 
		m = new StringBuffer(str);
		return str.toString();
	} else if ((str.indexOf("!simplify") != -1) 
			&& (str.indexOf("!d/d") == -1)) {
		//덜令頓炬
		String n = null;
		n = m.toString().replace(
				str.toString().toCharArray()[ten],
				str.toString().toCharArray()[twelve]
						);
		return n;
		} else if ((str.indexOf("!simplify") == -1) 
				&& (str.indexOf("!d/d") != -1)) { 
			//헹돔頓炬
			String o = null;
			String[] fstr = new String[ten];
			int numOfAdd = 0;
			StringBuffer w = new StringBuffer();
			StringBuffer wout = new StringBuffer();
			o = m.toString();
			for (int i = 0; i <= o.length(); i++) {		
				if (i == o.length()) {
					fstr[numOfAdd] = w.toString();
					w.setLength(0);
					numOfAdd++;
				} else if (o.toCharArray()[i] != '+') {
					w.append(o.toCharArray()[i]);
				} else {	
					fstr[numOfAdd] = w.toString();
					w.setLength(0);
					numOfAdd++;
				}
			}
	
			boolean flag = false;
			for (int j = 0; j < numOfAdd; j++) {		
				int numOfVar = 0;
				for (int d = 0; d < fstr[j].length(); d++) {	
					if (fstr[j].toCharArray()[d] 
							== str.toString().toCharArray()[four]) {
						numOfVar++;
					}
				}
				if (numOfVar > 0) {
					flag = true;
					for (int d = 0; d < fstr[j].length(); d++) {	
						if (fstr[j].toCharArray()[d] 
								== str.toString().toCharArray()[four]) {
							String s = (Integer.valueOf(numOfVar)).toString();
				            for (int k = 0; k < fstr[j].length(); k++) {
				            	if (k != d) {
				            		wout.append(fstr[j].toCharArray()[k]);
				            	} else {
				            		wout.append(s);
				            	}
				            }  
				            wout.append("+");
				            break;            
						}
					}
				}	
			}
			if (!flag) {
				return "error,no variable!";
			}
			return wout.deleteCharAt(wout.length() - 1).toString();	
		}
		return null;
	}
}

