package protest2;
import java.util.Scanner; 


class Exspression {
	//存储输入的字符串

	private StringBuffer thisExpression;

	public StringBuffer in() {
		Scanner input = new Scanner(System.in);
		String inputExpression = input.nextLine();
		thisExpression = new StringBuffer();
		thisExpression.append(inputExpression);
		return thisExpression;
	}
	
}

class Simplify {
	//处理多项式进行代值，求导。
	private StringBuffer thisExpression;
	public	String out(final StringBuffer  inputString) {
		//输入多项式
		final int theX = 10;
		final int theNum = 12;
		final int theDx = 4;
		if ((inputString.indexOf("!simplify") == -1) && (inputString.indexOf("!d/d") == -1)) {
			//inputString.in(); 
			thisExpression = new StringBuffer(inputString);
			return inputString.toString();
		} else if ((inputString.indexOf("!simplify") != -1) 
				&& (inputString.indexOf("!d/d") == -1)) {
			//代值运算
			String n = new String();
			n = thisExpression.toString().replace(
					inputString.toString().toCharArray()[theX],
					inputString.toString().toCharArray()[theNum]
							);
			return n;
		} else if ((inputString.indexOf("!simplify") == -1) 
					&& (inputString.indexOf("!d/d") != -1)) { 
			//求导运算
			String o = new String();
			String[] fstr = new String[10];
			int q1 = 0;
			StringBuffer w = new StringBuffer();
			StringBuffer resultString = new StringBuffer();
			o = thisExpression.toString();
			for (int i = 0; i <= o.length(); i++) {		
				if (i == o.length()) {
					fstr[q1] = w.toString();
					w.setLength(0);
					q1++;
				} else if (o.toCharArray()[i] != '+') {
					w.append(o.toCharArray()[i]);
				} else {
					fstr[q1] = w.toString();
					w.setLength(0);
					q1++;
				}
			}
			boolean flag = false;
			for (int j = 0; j < q1; j++) {
				int q2 = 0;
				for (int d = 0; d < fstr[j].length(); d++) {	
					if (fstr[j].toCharArray()[d] 
							== inputString.toString().toCharArray()[theDx]) {
						q2++;
					}
				}
				if (q2 > 0) {
					flag = true;
					for (int d = 0; d < fstr[j].length(); d++) {	
						if (fstr[j].toCharArray()[d] 
								== inputString.toString().toCharArray()[theDx]) {
							String s = (new Integer(q2)).toString();
				            for (int k = 0; k < fstr[j].length(); k++) {
				            	if (k != d) {
				            		resultString.append(fstr[j].toCharArray()[k]);
				            	} else {
				            		resultString.append(s);
				            	}
				            }
				            resultString.append("+");
				            break;            
						}
					}
				}			
				}
				if (!flag) {
					return "error,no variable!";
				}
				return resultString.deleteCharAt(resultString.length() - 1).toString();
			}
		return null;
	}
}

public class Test {
	public static void main(final String[] args) {		
		Simplify result = new Simplify();
		while (true) {	
			String outstr = new String();
			Exspression form = new Exspression();
			
			outstr = result.out(form.in());
			System.out.println(outstr);
		}
	}
}
